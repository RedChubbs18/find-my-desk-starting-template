{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@team-orbit/contracts": ["packages/contracts/src"],
      "@team-orbit/auth": ["packages/auth/src"],
      "@team-orbit/observability": ["packages/observability/src"],
      "@team-orbit/http-client": ["packages/http-client/src"]
    }
  },
  "include": ["packages/**/*", "services/**/*", "apps/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
